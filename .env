PORT=8080
APP_ENV=local

# Database (SQLite3)
# foreign_keys(1) enables foreign key constraints
# journal_mode(WAL) enables Write-Ahead Logging for better concurrent reads and writes
# busy_timeout: also upto 5 seconds to wait for the database to become available if it's locked
DB_URL="file:local_lms.db?_pragma=foreign_keys(1)&_pragma=journal_mode(WAL)&_pragma=busy_timeout(5000)"

# Allowed Origins
ALLOWED_ORIGIN=http://localhost:5173
